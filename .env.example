# Copia este archivo como .env y rellena los valores reales
# cp .env.example .env

# Alibaba DashScope LLM
ALIBABA_API_KEY=sk-REEMPLAZA_CON_TU_API_KEY
DASHSCOPE_INTL=true                  # true = endpoint Singapur, false = China
ALIBABA_MODEL=qwen-max               # Opciones: qwen-max, qwen3-coder-plus, qwen-plus

# Base de datos MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=REEMPLAZA_CON_TU_PASSWORD
DB_NAME=auth_system

# JWT
JWT_SECRET=REEMPLAZA_CON_UN_SECRET_DE_AL_MENOS_32_CARACTERES
JWT_EXPIRES_IN=24h

# Puertos del agente
HARNESS_PORT=5173
AGENT_PORT=3001
